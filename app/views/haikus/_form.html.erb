<%= form_with(model: @haiku) do |f| %>
  <%= render 'shared/error_messages',
             object: @haiku %>

  <div class="form-group">
    <%= f.label :body, '句' %>
    <%= f.text_field :body, class: 'form-control',
        data: {
          controller: 'char-count',
          char_count_target: 'input',
          action: 'input->char-count#count'
        } %>
    <span class="haiku-form__char-count"
          data-char-count-target="display">
      0 / 30文字
    </span>
  </div>

  <div class="form-group">
    <%= f.label :kigo, '季語' %>
    <%= f.text_field :kigo, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :theme, 'お題' %>
    <%= f.text_field :theme, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :description, '作者メモ' %>
    <%= f.text_area :description, class: 'form-control',
        rows: 3 %>
  </div>

  <div class="form-group">
    <%= f.label :status, '公開設定' %>
    <%= f.select :status,
        Haiku.statuses.keys
             .reject { |s| s == 'submitted_to_admin' }
             .map { |s|
               [t("haiku.status.#{s}"), s]
             },
        {},
        class: 'form-control' %>
  </div>

  <%= f.submit class: 'btn btn-primary' %>
<% end %>
