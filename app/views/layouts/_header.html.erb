<header class="navbar navbar-fixed-top navbar-inverse">
  <div class="container">
    <%= link_to (logged_in? ? current_user : root_path), class: 'logo' do %>
      オンライン句会
      <% if logged_in? %>
        <% if current_user.admin? %>
          <span class="label  label-danger">管理者</span>
        <% else %>
          <span class="label label-success">一般</span>
        <% end %>
      <% end %>
    <% end %>
    <nav>
      <ul class="nav navbar-nav navbar-right">
        <% if logged_in? %>
          <li><%= link_to '俳句一覧', haikus_path %></li>
          <li>
            <%= link_to '投稿する', new_haiku_path %>
          </li>
            <li>
              <%= link_to 'ユーザー一覧',
                  users_path %>
            </li>
              <% if current_user.admin? %>
            <li>
              <%= link_to submission_status_topic_assignments_path do %>
                提出状況
                <% count = Haiku.pending_review.count %>
                <% if count.positive? %>
                  <span class="badge"
                        style="background-color: #f0ad4e;">
                    <%= count %>
                  </span>
                <% end %>
              <% end %>
            </li>
          <% end %>
          <li>
            <%= link_to topic_assignments_path do %>
              通知
              <% unread_count = current_user.topic_assignments.active.unread.count %>
              <% if unread_count.positive? %>
                <span class="badge"
                      style="background-color: #d9534f;">
                  <%= unread_count %>
                </span>
              <% end %>
            <% end %>
          </li>
          <li class="dropdown">
            <a href="#" class="dropdown-toggle"
               data-toggle="dropdown">
              メニュー <b class="caret"></b>
            </a>
            <ul class="dropdown-menu">
              <li>
                <%= link_to 'マイ俳句',
                    mine_haikus_path %>
              </li>
              <li>
                <%= link_to 'マイページ',
                    current_user %>
              </li>
              <li class="divider"></li>
              <li>
                <%= link_to 'ログアウト',
                    logout_path,
                    data: {
                      turbo_method: :delete
                    } %>
              </li>
            </ul>
          </li>
        <% else %>
          <li><%= link_to 'ログイン', login_path %></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
