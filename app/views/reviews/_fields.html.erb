<% error_id = f.object.new_record? ? "new_review_errors" : "review_#{f.object.id}_errors" %>
<div id="<%= error_id %>">
  <%= render 'reviews/errors', review: f.object if f.object.errors.any? %>
</div>

<div class="form-group">
  <%= f.label :score, '評価（1〜5）' %>
  <%= f.select :score,
      (1..5).map { |n| ["#{'★' * n}#{'☆' * (5 - n)}", n] },
      { include_blank: '選択してください' },
      class: 'form-control' %>
</div>

<div class="form-group">
  <%= f.label :comment, '寸評' %>
  <%= f.text_area :comment, class: 'form-control',
      rows: 3 %>
</div>

<div class="form-group">
  <%= f.label :correction_body, '添削案' %>
  <%= f.text_field :correction_body,
      class: 'form-control' %>
</div>

<div class="form-group">
  <%= f.label :correction_reason, '添削理由' %>
  <%= f.text_area :correction_reason,
      class: 'form-control', rows: 2 %>
</div>
