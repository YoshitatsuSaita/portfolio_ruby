<%= form_with(model: @haiku) do |f| %>
  <%= render 'shared/error_messages',
             object: @haiku %>

  <div class="form-group">
    <%= f.label :theme, 'お題' %>
    <% if @haiku.new_record? && @haiku.theme.present? %>
      <%= f.text_field :theme, class: 'form-control',
          readonly: true, style: 'background-color: #f5f5f5;' %>
    <% else %>
      <%= f.text_field :theme, class: 'form-control' %>
    <% end %>
  </div>

  <div class="form-group">
    <%= f.label :body, '句' %>
    <%= f.text_field :body, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :kigo, '季語' %>
    <%= f.text_field :kigo, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :description, '作者メモ' %>
    <%= f.text_area :description, class: 'form-control',
        rows: 3 %>
  </div>

  <div class="form-group">
    <%= f.label :status, '公開設定' %>
    <% status_keys = @from_topic ? %w[draft submitted_to_admin] : %w[draft published] %>
    <%= f.select :status,
        status_keys.map { |s|
          [t("haiku.status.#{s}"), s]
        },
        {},
        class: 'form-control' %>
  </div>

  <%= f.submit class: 'btn btn-primary' %>
<% end %>
