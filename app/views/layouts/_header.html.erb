<header class="navbar navbar-fixed-top navbar-inverse">
  <div class="container">
    <%= link_to '句会', root_path, class: 'logo' %>
    <nav>
      <ul class="nav navbar-nav navbar-right">
        <% if logged_in? %>
          <li><%= link_to '俳句一覧', haikus_path %></li>
          <li>
            <%= link_to '投稿する', new_haiku_path %>
          </li>
          <% if current_user.admin? %>
            <li>
              <%= link_to 'ユーザー一覧',
                  users_path %>
            </li>
            <li>
              <%= link_to pending_review_haikus_path do %>
                評価待ち
                <% count = Haiku.pending_review.count %>
                <% if count.positive? %>
                  <span class="badge"><%= count %></span>
                <% end %>
              <% end %>
            </li>
          <% end %>
          <li class="dropdown">
            <a href="#" class="dropdown-toggle"
               data-toggle="dropdown">
              メニュー <b class="caret"></b>
            </a>
            <ul class="dropdown-menu">
              <li>
                <%= link_to 'マイ俳句',
                    mine_haikus_path %>
              </li>
              <li>
                <%= link_to 'マイページ',
                    current_user %>
              </li>
              <li>
                <%= link_to '設定',
                    edit_user_path(current_user) %>
              </li>
              <li class="divider"></li>
              <li>
                <%= link_to 'ログアウト',
                    logout_path,
                    data: {
                      turbo_method: :delete
                    } %>
              </li>
            </ul>
          </li>
        <% else %>
          <li><%= link_to 'ログイン', login_path %></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
