<% provide(:title, 'お題を編集') %>
<h1>お題を編集</h1>

<div class="row">
  <div class="col-md-8 col-md-offset-2">
    <div class="well">
      <p><strong>お題:</strong> <%= @theme %></p>
      <% if @deadline.present? %>
        <p><strong>期日:</strong> <%= l(@deadline) %></p>
      <% end %>
    </div>

    <%= form_tag topic_assignment_path(@assignment), method: :patch do %>
      <div class="form-group">
        <label>送信先ユーザー</label>
        <div class="well" style="max-height: 300px; overflow-y: auto;">
          <div class="checkbox">
            <label>
              <input type="checkbox" id="select-all-users">
              <strong>全員を選択</strong>
            </label>
          </div>
          <hr style="margin: 5px 0;">
          <% @users.each do |user| %>
            <div class="checkbox">
              <label>
                <%= check_box_tag 'user_ids[]', user.id,
                    @existing_user_ids.include?(user.id),
                    class: 'user-checkbox' %>
                <%= user.name %>
              </label>
            </div>
          <% end %>
        </div>
      </div>

      <%= submit_tag '更新する', class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var selectAll = document.getElementById('select-all-users');
    if (selectAll) {
      var checkboxes = document.querySelectorAll('.user-checkbox');
      function updateSelectAll() {
        selectAll.checked = Array.from(checkboxes).every(function(cb) { return cb.checked; });
      }
      selectAll.addEventListener('change', function() {
        checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
      });
      checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateSelectAll);
      });
      updateSelectAll();
    }
  });
</script>
