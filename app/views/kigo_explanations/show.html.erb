<%= turbo_frame_tag 'kigo_explanation' do %>
  <div class="kigo-explanation">
    <% if @error %>
      <p class="kigo-explanation__error text-danger">
        <%= @error %>
      </p>
      <%= link_to '再試行',
          haiku_kigo_explanation_path(@haiku),
          class: 'btn btn-info btn-sm',
          data: { turbo_frame: 'kigo_explanation' } %>
    <% elsif @explanation.none_season? %>
      <p class="kigo-explanation__none">
        「<%= @explanation.kigo_word %>」は季語ではありません（無季）。
      </p>
    <% else %>
      <h4 class="kigo-explanation__title">
        季語解説: <%= @explanation.kigo_word %>
        <% if @explanation.canonical_word.present? %>
          （正式: <%= @explanation.canonical_word %>）
        <% end %>
      </h4>
      <p class="kigo-explanation__season">
        季節: <%= @explanation.season %>
      </p>
      <% if @explanation.parent_kigo.present? %>
        <p class="kigo-explanation__parent">
          親季語: <%= @explanation.parent_kigo %>
        </p>
      <% end %>
      <% if @explanation.explanation.present? %>
        <p class="kigo-explanation__text">
          <%= @explanation.explanation %>
        </p>
      <% end %>
    <% end %>
    <% unless @error %>
      <%= link_to '再検索',
          haiku_kigo_explanation_path(@haiku),
          data: {
            turbo_method: :delete,
            turbo_frame: 'kigo_explanation'
          },
          class: 'btn btn-warning btn-sm',
          onclick: "this.textContent='読み込み中…'; this.classList.replace('btn-warning','btn-default'); this.disabled=true" %>
    <% end %>
  </div>
<% end %>
