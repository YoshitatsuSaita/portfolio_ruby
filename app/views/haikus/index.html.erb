<% provide(:title, '俳句一覧') %>
<h1>俳句一覧</h1>

<div class="row">
  <div class="col-md-8 col-md-offset-2">
    <%= render 'filter' %>

    <% if @haikus.any? %>
      <%= will_paginate @haikus %>
      <% @haikus.each do |haiku| %>
        <%= render 'haiku', haiku: haiku %>
      <% end %>
      <%= will_paginate @haikus %>
    <% else %>
      <p>俳句はまだ投稿されていません。</p>
    <% end %>
  </div>
</div>
