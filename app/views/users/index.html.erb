<% provide(:title, 'ユーザー一覧') %>
<h1>ユーザー一覧</h1>

<div class="col-md-10 col-md-offset-1">
  <%= will_paginate %>
  <table class="table table-condensed table-hover table-users">
    <thead>
      <tr>
        <th>名前</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= link_to user.name, user %></td>
          <% if current_user.admin? %>
            <td class="center">
              <%= link_to '設定', edit_user_path(user), class: 'btn btn-default btn-xs' %>
              <% unless current_user?(user) %>
                <%= link_to '削除', user,
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "#{user.name}を削除してよろしいですか？"
                    },
                    class: 'btn btn-danger btn-xs' %>
              <% end %>
            </td>
          <% else %>
            <td></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= will_paginate %>
</div>
