<% provide(:title, @haiku.body.truncate(20)) %>

<div class="row">
  <div class="col-md-8 col-md-offset-2">
    <div class="haiku-show">
      <p class="haiku-show__body">
        <%= @haiku.body %>
        <% unless @haiku.published? %>
          <span class="label label-warning">
            <%= t("haiku.status.#{@haiku.status}") %>
          </span>
        <% end %>
      </p>
      <p class="haiku-show__meta">
        <span class="haiku-show__kigo">
          季語: <%= @haiku.kigo %>
        </span>
        <% if @haiku.theme.present? %>
          <span class="haiku-show__theme">
            お題: <%= @haiku.theme %>
          </span>
        <% end %>
      </p>
      <% if @haiku.description.present? %>
        <p class="haiku-show__description">
          <%= @haiku.description %>
        </p>
      <% end %>
      <p class="haiku-show__author">
        投稿者:
        <span data-controller="blind-author"
              data-blind-author-name-value="<%= @haiku.user.name %>"
              data-blind-author-path-value="<%= user_path(@haiku.user) %>">
          <span data-blind-author-target="display">
            ***
          </span>
          <button class="btn btn-xs btn-default"
                  data-action="blind-author#reveal"
                  data-blind-author-target="button">
            投稿者を表示
          </button>
        </span>
      </p>
      <p class="haiku-show__time">
        <%= l @haiku.created_at, format: :long %>
      </p>
      <%= turbo_frame_tag 'kigo_explanation' do %>
        <%= link_to '季語解説を見る',
            haiku_kigo_explanation_path(@haiku),
            class: 'btn btn-info btn-sm',
            data: { turbo_frame: 'kigo_explanation' },
            onclick: "this.disabled=true; this.textContent='読み込み中…'; this.classList.replace('btn-info','btn-default')" %>
      <% end %>
      <% if @haiku.user == current_user %>
        <div class="haiku-show__actions">
          <% if @haiku.reviewed_by_admin? %>
            <p class="text-muted">
              管理者の評価済みのため編集できません。
            </p>
          <% else %>
            <%= link_to '編集',
                edit_haiku_path(@haiku),
                class: 'btn btn-primary' %>
          <% end %>
          <%= link_to '削除',
              haiku_path(@haiku),
              data: {
                turbo_method: :delete,
                turbo_confirm: '本当に削除しますか？'
              },
              class: 'btn btn-danger' %>
        </div>
      <% end %>
    </div>

    <% if @reviews.any? %>
      <div class="review-summary">
        <h3>
          評価
          <span class="review-summary__average">
            平均: <%= format('%.1f',
                @reviews.average(:score)) %> / 5
          </span>
          <span class="review-summary__count">
            （<%= @reviews.size %>件）
          </span>
        </h3>
      </div>
    <% end %>

    <% @reviews.each do |review| %>
      <div class="review-card <%= 'review-card--admin' if review.user.admin? %>">
        <div class="review-card__header">
          <span class="review-card__score">
            <% 5.times do |i| %>
              <% if i < review.score %>
                ★
              <% else %>
                ☆
              <% end %>
            <% end %>
          </span>
          <span class="review-card__reviewer">
            <%= review.user.name %>
          </span>
          <span class="review-card__time">
            <%= l review.created_at, format: :short %>
          </span>
        </div>
        <% if review.comment.present? %>
          <p class="review-card__comment">
            <%= review.comment %>
          </p>
        <% end %>
        <% if review.correction_body.present? %>
          <div class="review-card__correction">
            <p class="review-card__correction-label">
              添削案: <%= review.correction_body %>
            </p>
            <% if review.correction_reason.present? %>
              <p class="review-card__correction-reason">
                理由: <%= review.correction_reason %>
              </p>
            <% end %>
          </div>
        <% end %>
        <% if review.user == current_user %>
          <div class="review-card__actions" data-controller="modal">
            <button class="btn btn-xs btn-primary" data-action="modal#open">編集</button>
            <%= link_to '削除',
                haiku_review_path(@haiku, review),
                data: {
                  turbo_method: :delete,
                  turbo_confirm: '本当に削除しますか？'
                },
                class: 'btn btn-xs btn-danger' %>

            <div class="modal fade" data-modal-target="dialog" tabindex="-1" style="display: none;">
              <div class="modal-dialog">
                <div class="modal-content">
                  <%= form_with(model: [@haiku, review]) do |f| %>
                    <div class="modal-header">
                      <button type="button" class="close" data-action="modal#close">&times;</button>
                      <h4 class="modal-title">『<%= @haiku.body %>』 の評価を編集</h4>
                    </div>
                    <div class="modal-body">
                      <%= render 'reviews/fields', f: f %>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-default" data-action="modal#close">キャンセル</button>
                      <%= f.submit '更新する', class: 'btn btn-primary' %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @haiku.user != current_user && !@review.persisted? %>
      <div class="review-form" data-controller="modal">
        <button class="btn btn-primary" data-action="modal#open">評価する</button>

        <div class="modal fade" data-modal-target="dialog" tabindex="-1" style="display: none;">
          <div class="modal-dialog">
            <div class="modal-content">
              <%= form_with(model: [@haiku, @review]) do |f| %>
                <div class="modal-header">
                  <button type="button" class="close" data-action="modal#close">&times;</button>
                  <h4 class="modal-title">『<%= @haiku.body %>』 の評価を作成</h4>
                </div>
                <div class="modal-body">
                  <%= render 'reviews/fields', f: f %>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-default" data-action="modal#close">キャンセル</button>
                  <%= f.submit '投稿する', class: 'btn btn-primary' %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
